  "llm": {
    "_comment": "默认 LLM 配置 - 用于基本对话",
    "provider": "ollama",
    "_provider_comment": "提供商：ollama, openai, anthropic, custom",
    "api_key": "ollama",
    "_api_key_comment": "API密钥，本地模型可填任意值",
    "base_url": "http://localhost:11434/v1",
