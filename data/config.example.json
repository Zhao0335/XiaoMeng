    "_model_comment": "模型名称，需要与 Ollama 中 pull 的模型一致",
    "max_tokens": 4096,
    "_max_tokens_comment": "最大输出长度",
    "temperature": 0.7,
    "_temperature_comment": "创造性程度，0-1，越高越随机"
