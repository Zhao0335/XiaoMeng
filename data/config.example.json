        {
          "model_id": "qwen-brain",
          "layer": "brain",
          "role": "reasoning",
          "endpoint": "http://localhost:11434/v1",
          "model_name": "qwen2.5:14b",
          "api_key": null,
          "max_tokens": 8192,
          "temperature": 0.5,
          "timeout": 120,
          "enabled": true,
          "priority": 1
        }
      ]
    },
    "special_layer": {
